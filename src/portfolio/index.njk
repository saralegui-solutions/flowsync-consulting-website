---
layout: layouts/base.njk
title: Portfolio
description: Real-world NetSuite automation and integration solutions delivering measurable ROI and 100% user adoption
---

{# Hero Section with Aggregate Stats #}
<div class="bg-gradient-to-br from-primary to-primary-dark text-white py-20 px-4">
    <div class="container mx-auto max-w-5xl text-center">
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold mb-6">Real Solutions, Real Results</h1>
        <p class="text-xl sm:text-2xl text-blue-200 mb-10 max-w-3xl mx-auto">
            NetSuite automation and integration projects that deliver measurable ROI and 100% user adoption
        </p>

        {# Aggregate Metrics #}
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mt-12">
            <div class="text-center">
                <div class="text-4xl font-bold text-green-300">$750K+</div>
                <div class="text-sm text-gray-300 uppercase tracking-wide mt-1">Annual Value Delivered</div>
            </div>
            <div class="text-center">
                <div class="text-4xl font-bold text-green-300">500+</div>
                <div class="text-sm text-gray-300 uppercase tracking-wide mt-1">Hours/Month Saved</div>
            </div>
            <div class="text-center">
                <div class="text-4xl font-bold text-green-300">100%</div>
                <div class="text-sm text-gray-300 uppercase tracking-wide mt-1">User Adoption Rate</div>
            </div>
            <div class="text-center">
                <div class="text-4xl font-bold text-green-300">9</div>
                <div class="text-sm text-gray-300 uppercase tracking-wide mt-1">Featured Projects</div>
            </div>
        </div>
    </div>
</div>

{# Filter Buttons #}
<div class="bg-gray-50 border-b border-gray-200 py-6" x-data="{ filter: 'All' }" x-cloak>
    <div class="container mx-auto px-4 max-w-6xl">
        <div class="flex flex-wrap gap-3 justify-center">
            <button @click="filter = 'All'" :class="filter === 'All' ? 'bg-primary text-white' : 'bg-white text-gray-700 hover:bg-gray-100'"
                    class="px-5 py-2 rounded-lg font-semibold transition-colors border border-gray-300">
                All Projects
            </button>
            <button @click="filter = 'Automation'" :class="filter === 'Automation' ? 'bg-primary text-white' : 'bg-white text-gray-700 hover:bg-gray-100'"
                    class="px-5 py-2 rounded-lg font-semibold transition-colors border border-gray-300">
                Automation
            </button>
            <button @click="filter = 'Integration'" :class="filter === 'Integration' ? 'bg-primary text-white' : 'bg-white text-gray-700 hover:bg-gray-100'"
                    class="px-5 py-2 rounded-lg font-semibold transition-colors border border-gray-300">
                Integration
            </button>
            <button @click="filter = 'Suitelet'" :class="filter === 'Suitelet' ? 'bg-primary text-white' : 'bg-white text-gray-700 hover:bg-gray-100'"
                    class="px-5 py-2 rounded-lg font-semibold transition-colors border border-gray-300">
                Suitelet
            </button>
            <button @click="filter = 'Document'" :class="filter === 'Document' ? 'bg-primary text-white' : 'bg-white text-gray-700 hover:bg-gray-100'"
                    class="px-5 py-2 rounded-lg font-semibold transition-colors border border-gray-300">
                Document
            </button>
        </div>
    </div>

    {# Case Study Cards Grid #}
    <div class="container mx-auto px-4 py-12 max-w-6xl">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

            {% set caseStudies = collections.portfolio | sort(attribute='data.order') %}
            {% for study in caseStudies %}
            <div x-show="filter === 'All' || filter === '{{ study.data.category }}'"
                 x-transition:enter="transition ease-out duration-200"
                 x-transition:enter-start="opacity-0 scale-95"
                 x-transition:enter-end="opacity-100 scale-100"
                 x-transition:leave="transition ease-in duration-150"
                 x-transition:leave-start="opacity-100 scale-100"
                 x-transition:leave-end="opacity-0 scale-95"
                 class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-200">

                {# Category Badge #}
                <div class="bg-gradient-to-br from-primary to-primary-dark p-4">
                    <span class="inline-block px-3 py-1 bg-white text-primary text-xs font-bold rounded-full uppercase tracking-wide">
                        {{ study.data.category }}
                    </span>
                    {% if study.data.industry %}
                    <p class="text-blue-200 text-xs mt-2">{{ study.data.industry }}</p>
                    {% endif %}
                </div>

                {# Card Content #}
                <div class="p-5">
                    <h3 class="text-xl font-bold text-primary mb-2 leading-tight">{{ study.data.title }}</h3>
                    <p class="text-gray-600 text-sm mb-4">{{ study.data.description }}</p>

                    {# Key Metrics (first 2) #}
                    {% if study.data.metrics %}
                    <div class="grid grid-cols-2 gap-3 mb-4">
                        {% for metric in study.data.metrics | slice(0, 2) %}
                        <div class="bg-gray-50 rounded p-2 text-center border border-gray-200">
                            <div class="text-lg font-bold text-primary">{{ metric.value }}</div>
                            <div class="text-xs text-gray-600">{{ metric.label }}</div>
                        </div>
                        {% endfor %}
                    </div>
                    {% endif %}

                    {# Tech Badges (first 3) #}
                    {% if study.data.techTags %}
                    <div class="flex flex-wrap gap-1 mb-4">
                        {% for tag in study.data.techTags | slice(0, 3) %}
                        <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold bg-gray-100 text-gray-700">{{ tag }}</span>
                        {% endfor %}
                        {% if study.data.techTags.length > 3 %}
                        <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold text-gray-500">+{{ study.data.techTags.length - 3 }} more</span>
                        {% endif %}
                    </div>
                    {% endif %}

                    {# Read More Link #}
                    <a href="{{ study.url }}" class="inline-flex items-center gap-2 text-accent hover:text-accent-dark font-semibold text-sm transition-colors">
                        View Case Study
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                        </svg>
                    </a>
                </div>
            </div>
            {% endfor %}

        </div>
    </div>
</div>

{# Bottom CTA #}
<div class="bg-gray-900 text-white py-16 px-4">
    <div class="container mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold mb-4">Ready to Transform Your NetSuite Operations?</h2>
        <p class="text-xl text-gray-300 mb-8">
            Let's build a custom solution that delivers measurable ROI and 100% user adoption.
        </p>
        <a href="/contact/" class="inline-block bg-accent hover:bg-accent-dark text-white font-bold py-4 px-10 rounded-lg text-lg transition-colors">
            Start Your Project
        </a>
    </div>
</div>
