<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | {{ site.name }}</title>
    <meta name="description" content="{{ description or site.description }}">

    <!-- Open Graph -->
    <meta property="og:title" content="{{ title }} | {{ site.name }}">
    <meta property="og:description" content="{{ description or site.description }}">
    <meta property="og:url" content="{{ site.url }}{{ page.url }}">
    <meta property="og:type" content="website">

    <!-- Favicon -->
    <link rel="icon" href="/assets/favicon.ico">

    <!-- Styles -->
    <link rel="stylesheet" href="/css/main.css">

    <!-- Alpine.js for interactions (self-hosted) -->
    <script defer src="/js/alpine.min.js"></script>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "name": "FlowSync Consulting",
          "url": "https://flowsync-consulting-website.pages.dev",
          "description": "NetSuite workflow automation and system integration consulting. We deliver measurable ROI through custom solutions with 100% user adoption.",
          "address": {
            "@type": "PostalAddress",
            "addressCountry": "US"
          },
          "areaServed": {
            "@type": "Country",
            "name": "United States"
          }
        },
        {
          "@type": "ProfessionalService",
          "name": "NetSuite Consulting Services",
          "provider": {
            "@type": "Organization",
            "name": "FlowSync Consulting"
          },
          "serviceType": "NetSuite Workflow Automation and System Integration",
          "description": "Custom NetSuite solutions including workflow automation, system integration, custom Suitelets, SuiteScript development, and process optimization.",
          "areaServed": {
            "@type": "Country",
            "name": "United States"
          }
        }
      ]
    }
    </script>
</head>
<body class="flex flex-col min-h-screen bg-bg-warm text-text-primary">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:bg-white focus:text-primary focus:px-4 focus:py-2 focus:rounded-lg focus:shadow-lg focus:font-semibold">Skip to content</a>
    {% include "partials/header.njk" %}

    <main id="main-content" class="flex-grow">
        {{ content | safe }}
    </main>

    {% include "partials/footer.njk" %}

    <!-- Global JavaScript -->
    <script src="/js/main.js"></script>
</body>
</html>
