---
layout: layouts/base.njk
---

{# Breadcrumbs #}
<div class="bg-gray-50 border-b border-gray-200">
    <div class="container mx-auto px-4 py-3">
        <nav class="flex text-sm text-gray-600" aria-label="Breadcrumb">
            <a href="/" class="hover:text-primary">Home</a>
            <span class="mx-2">/</span>
            <a href="/portfolio/" class="hover:text-primary">Portfolio</a>
            <span class="mx-2">/</span>
            <span class="text-gray-900">{{ title }}</span>
        </nav>
    </div>
</div>

{# Hero Section with Metrics #}
<div class="bg-gradient-to-br from-primary to-primary-dark text-white py-16 px-4">
    <div class="container mx-auto max-w-5xl text-center">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 leading-tight">{{ title }}</h1>
        <p class="text-lg sm:text-xl text-blue-200 mb-8 max-w-3xl mx-auto">{{ tagline }}</p>

        {# Metrics Grid #}
        <div class="flex justify-center gap-8 flex-wrap mt-10">
            {% for metric in metrics %}
            <div class="text-center">
                <div class="text-3xl sm:text-4xl font-bold text-green-300">{{ metric.value }}</div>
                <div class="text-xs sm:text-sm text-gray-300 uppercase tracking-wide mt-1">{{ metric.label }}</div>
            </div>
            {% endfor %}
        </div>
    </div>
</div>

{# Main Content #}
<div class="container mx-auto px-4 py-10 max-w-4xl">

    {# Category and Tags #}
    <div class="mb-8 flex flex-wrap gap-2 items-center">
        <span class="inline-block px-3 py-1 bg-primary text-white text-xs font-semibold rounded-full uppercase tracking-wide">{{ category }}</span>
        {% if industry %}
        <span class="text-gray-600 text-sm">{{ industry }}</span>
        {% endif %}
    </div>

    {# Main Body Content #}
    <div class="prose prose-lg max-w-none">
        {{ content | safe }}
    </div>

    {# Technology Tags #}
    {% if techTags and techTags.length > 0 %}
    <div class="mt-10 pt-6 border-t border-gray-200">
        <h3 class="text-lg font-semibold text-primary mb-3">Technologies Used</h3>
        <div class="flex flex-wrap gap-2">
            {% for tag in techTags %}
            <span class="inline-block px-3 py-1 rounded-full text-sm font-semibold bg-gray-100 text-primary-light border border-gray-200">{{ tag }}</span>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    {# CTA Section #}
    <div class="mt-12 bg-gradient-to-br from-primary to-primary-dark text-white rounded-lg p-8 text-center">
        <h2 class="text-2xl font-bold mb-3">Facing a Similar Challenge?</h2>
        <p class="text-blue-200 mb-6">Let's discuss how we can deliver measurable results for your business.</p>
        <a href="/contact/" class="inline-block bg-accent hover:bg-accent-dark text-white font-bold py-3 px-8 rounded-lg transition-colors">
            Let's Talk
        </a>
    </div>

    {# Back to Portfolio Link #}
    <div class="mt-8 text-center">
        <a href="/portfolio/" class="text-primary hover:text-primary-light font-medium inline-flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Back to Portfolio
        </a>
    </div>

    {# Related Case Studies - Placeholder for future enhancement #}
    {# TODO: Add logic to show 2-3 other case studies from the same category #}
</div>
