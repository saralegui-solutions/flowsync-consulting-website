<div class="container mx-auto px-4 py-8 md:py-12 max-w-5xl">
    {% if showTitle !== false %}
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-primary mb-6">{{ title }}</h1>
    {% endif %}

    <div class="prose prose-base md:prose-lg max-w-none">
        {{ content | safe }}
    </div>
</div>
